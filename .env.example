# =========================================
# Smart Study Router - Environment Template
# Copy this file to `.env` and fill in your real values.
# =========================================

# ===== Upstream LLM Provider =====

# OpenAI-compatible API base URL
UPSTREAM_BASE_URL=https://your-model-provider.example.com/v1

# API key for the upstream provider
UPSTREAM_API_KEY=your_upstream_api_key_here

# ===== Models =====

# Model used for classification / routing decisions
CLASSIFIER_MODEL=your_classifier_model_name

# Model used for final response generation
ANSWER_MODEL=your_answer_model_name

# ===== Server =====

# Port for the local HTTP server
PORT=8787